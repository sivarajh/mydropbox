# Copy this file to `.env` for local development and fill in the values from
# your Supabase project: Dashboard -> Project Settings -> API.
#
# These are the *public* anon values and are safe to expose in the browser;
# your data is protected by Row-Level Security policies (see supabase/schema.sql).

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The Google Apps Script Web App URL that proxies file storage to your personal
# Google Drive (ends in /exec). See google-apps-script/README.md.
VITE_PROXY_URL=https://script.google.com/macros/s/XXXX/exec
